name: Deploy

on:
  push:
    branches: [main]

jobs:
{{#hasWeb}}
  deploy-web:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - run: npm ci
      - run: npm run build:web

      {{#isCloudflarePages}}
      - uses: cloudflare/wrangler-action@v3
        with:
          apiToken: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          command: pages deploy apps/web/dist --project-name {{projectName}}
      {{/isCloudflarePages}}

      {{#isVercel}}
      - run: npx vercel --prod --token ${{ secrets.VERCEL_TOKEN }}
        working-directory: apps/web
      {{/isVercel}}

      {{#isFirebaseHosting}}
      - uses: FirebaseExtended/action-hosting-deploy@v0
        with:
          repoToken: ${{ secrets.GITHUB_TOKEN }}
          firebaseServiceAccount: ${{ secrets.FIREBASE_SERVICE_ACCOUNT }}
          projectId: ${{ secrets.FIREBASE_PROJECT_ID }}
      {{/isFirebaseHosting}}

      {{#isNetlify}}
      - run: npx netlify-cli deploy --prod --dir apps/web/dist
        env:
          NETLIFY_AUTH_TOKEN: ${{ secrets.NETLIFY_AUTH_TOKEN }}
          NETLIFY_SITE_ID: ${{ secrets.NETLIFY_SITE_ID }}
      {{/isNetlify}}

{{/hasWeb}}
{{#hasApi}}
  deploy-api:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      {{#isCloudRun}}
      - uses: google-github-actions/auth@v2
        with:
          credentials_json: ${{ secrets.GCP_SA_KEY }}

      - uses: google-github-actions/setup-gcloud@v2

      - uses: google-github-actions/deploy-cloudrun@v2
        with:
          service: {{projectName}}-api
          source: ./apps/api
          region: ${{ secrets.GCP_REGION || 'us-central1' }}
      {{/isCloudRun}}

      {{#isFlyio}}
      - uses: superfly/flyctl-actions/setup-flyctl@master

      - run: flyctl deploy --remote-only
        working-directory: apps/api
        env:
          FLY_API_TOKEN: ${{ secrets.FLY_API_TOKEN }}
      {{/isFlyio}}

      {{#isRender}}
      # Render deploys automatically on push to main via its GitHub integration.
      # Connect your repo at https://dashboard.render.com and use the render.yaml in this repo.
      - run: echo "Render deploys automatically on push to main"
      {{/isRender}}

{{/hasApi}}
